# PostgreSQL connection
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/stock_analyzer

# CORS — frontend dev origin (comma-separated for multiple)
CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=INFO

# SEC EDGAR requires a descriptive User-Agent identifying the caller.
# Use your own name/app and a real contact email.
SEC_EDGAR_USER_AGENT=Your Name your-email@example.com

# Wikimedia (Wikipedia) API also expects a descriptive User-Agent.
WIKIPEDIA_USER_AGENT=Your Name your-email@example.com
